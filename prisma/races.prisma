enum RaceMode {
  solo
  team
}

model Race {
  id             Int           @id @default(autoincrement())
  name           String
  mode           RaceMode      @default(solo)
  raceDate       DateTime
  trackId        Int?
  track          Track?        @relation(fields: [trackId], references: [id], onDelete: SetNull)
  championshipId Int?
  championship   Championship? @relation(fields: [championshipId], references: [id], onDelete: SetNull)
  location       String?
  notes          String?
  results        RaceResult[]
  teams          RaceTeam[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([raceDate])
  @@index([trackId])
  @@index([championshipId])
}

model Track {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  races     Race[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model RaceTeam {
  id        Int              @id @default(autoincrement())
  raceId    Int
  name      String
  race      Race             @relation(fields: [raceId], references: [id], onDelete: Cascade)
  members   RaceTeamMember[]
  results   RaceResult[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([raceId, name])
  @@index([raceId])
}

model RaceTeamMember {
  raceTeamId Int
  pilotId    Int
  raceTeam   RaceTeam @relation(fields: [raceTeamId], references: [id], onDelete: Cascade)
  pilot      Pilot    @relation(fields: [pilotId], references: [id], onDelete: Cascade)

  @@id([raceTeamId, pilotId])
  @@index([pilotId])
}

model RaceResult {
  id        Int      @id @default(autoincrement())
  raceId    Int
  pilotId   Int?
  teamId    Int?
  carId     Int?
  position  Int
  laps      Int?
  bestLapMs Int?
  race      Race     @relation(fields: [raceId], references: [id], onDelete: Cascade)
  pilot     Pilot?   @relation(fields: [pilotId], references: [id], onDelete: Cascade)
  team      RaceTeam? @relation(fields: [teamId], references: [id], onDelete: Cascade)
  car       Car?     @relation(fields: [carId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([raceId, pilotId])
  @@unique([raceId, teamId])
  @@unique([raceId, position])
  @@index([pilotId])
  @@index([teamId])
  @@index([carId])
}
