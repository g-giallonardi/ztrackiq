enum ChampionshipMode {
  solo
  team
}

model Championship {
  id               Int       @id @default(autoincrement())
  name             String
  mode             ChampionshipMode @default(solo)
  startDate        DateTime
  endDate          DateTime?
  scoringMode      String    @default("ALL")
  bestRaceCount    Int?
  pointsByPosition Json
  races            Race[]
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([startDate, endDate])
}
